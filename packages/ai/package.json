{
  "name": "@loginwithchatgpt/ai",
  "version": "0.1.0",
  "description": "Vercel AI SDK provider for Login with ChatGPT with proxy/direct modes, model discovery, streaming, tools, and generateText/streamText.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "prepublishOnly": "rm -rf dist && bun run build"
  },
  "dependencies": {
    "@loginwithchatgpt/core": "workspace:*"
  },
  "peerDependencies": {
    "@ai-sdk/openai": "^4.0.0",
    "ai": "^7.0.0"
  },
  "keywords": [
    "chatgpt",
    "openai",
    "ai-sdk",
    "vercel",
    "codex",
    "provider",
    "streaming"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  }
}
