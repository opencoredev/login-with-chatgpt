{
  "name": "@loginwithchatgpt/core",
  "version": "0.1.0",
  "description": "Framework-agnostic engine for Login with ChatGPT: OAuth device-code + PKCE flows, token refresh, and the Codex responses transport.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "prepublishOnly": "rm -rf dist && bun run build"
  },
  "keywords": [
    "chatgpt",
    "openai",
    "oauth",
    "codex",
    "login",
    "auth",
    "device-code"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opencoredev/login-with-chatgpt.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/opencoredev/login-with-chatgpt#readme",
  "bugs": {
    "url": "https://github.com/opencoredev/login-with-chatgpt/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
