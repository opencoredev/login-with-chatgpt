{
  "name": "@loginwithchatgpt/server",
  "version": "0.1.0",
  "description": "Server handler for Login with ChatGPT: device login, session status, logout, model discovery, and an authenticated Codex responses proxy.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "prepublishOnly": "rm -rf dist && bun run build"
  },
  "dependencies": {
    "@loginwithchatgpt/core": "workspace:*"
  },
  "keywords": [
    "chatgpt",
    "openai",
    "oauth",
    "codex",
    "login",
    "auth",
    "edge",
    "serverless"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  }
}
